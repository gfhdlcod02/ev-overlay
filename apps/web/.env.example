# Web App Environment Variables

# =============================================================================
# API Configuration
# =============================================================================

# Base URL for the Cloudflare Worker API
# Replace with your deployed Worker URL or use relative path for local dev
VITE_API_URL=/api

# =============================================================================
# Geocoding Configuration
# =============================================================================

# Nominatim API base URL (OpenStreetMap geocoding)
# Default: https://nominatim.openstreetmap.org
# VITE_NOMINATIM_URL=https://nominatim.openstreetmap.org

# User agent for Nominatim requests (required by their Terms of Service)
# Default: EV-Overlay/1.0
# VITE_APP_USER_AGENT=EV-Overlay/1.0

# =============================================================================
# Map Configuration
# =============================================================================

# OpenStreetMap tile layer URL
# Default: https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Tile layer attribution (HTML string)
# Default: © OpenStreetMap contributors
# VITE_MAP_ATTRIBUTION=© OpenStreetMap contributors

# Maximum zoom level
# Default: 19
# VITE_MAP_MAX_ZOOM=19

# Default map center coordinates (Thailand/Bangkok)
# VITE_MAP_DEFAULT_LAT=13.7563
# VITE_MAP_DEFAULT_LNG=100.5018

# Default zoom level
# Default: 6
# VITE_MAP_DEFAULT_ZOOM=6

# =============================================================================
# Cache Configuration
# =============================================================================

# Route cache TTL in milliseconds
# Default: 60000 (60 seconds)
# VITE_CACHE_TTL_MS=60000

# Maximum cache entries
# Default: 50
# VITE_CACHE_MAX_SIZE=50

# =============================================================================
# Feature Flags
# =============================================================================

# Enable geolocation on startup
# Default: true
# VITE_ENABLE_GEOLOCATION=true

# Geolocation timeout in milliseconds
# Default: 5000
# VITE_GEOLOCATION_TIMEOUT_MS=5000

# Geolocation accuracy threshold in meters
# Default: 1000
# VITE_GEOLOCATION_ACCURACY_THRESHOLD=1000

# =============================================================================
# App Metadata
# =============================================================================

# Application name
# Default: EV Trip Planner
# VITE_APP_NAME=EV Trip Planner

# Application version (usually injected at build time)
# VITE_APP_VERSION=1.2.0
