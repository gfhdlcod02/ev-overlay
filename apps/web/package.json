{
  "name": "@ev/web",
  "version": "1.2.0",
  "description": "Vue 3 frontend for EV trip planning",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
