# Cloudflare Worker API Environment Variables

# =============================================================================
# OSRM (Open Source Routing Machine) Configuration
# =============================================================================

# Base URL for OSRM API
# Default: https://router.project-osrm.org
OSRM_BASE_URL=https://router.project-osrm.org

# Connection timeout in milliseconds
# Default: 5000
OSRM_CONNECT_TIMEOUT_MS=5000

# Request timeout in milliseconds
# Default: 20000
OSRM_REQUEST_TIMEOUT_MS=20000

# Number of retries on timeout
# Default: 1
OSRM_RETRIES=1

# =============================================================================
# Cache Configuration
# =============================================================================

# Cache TTL in seconds (default: 7 days)
# Default: 604800
CACHE_TTL_SECONDS=604800

# Cache key prefix
# Default: route:
CACHE_KEY_PREFIX=route:

# Coordinate precision for cache keys (decimal places)
# Default: 4 (~11m precision)
CACHE_COORDINATE_PRECISION=4

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# Maximum requests per window
# Default: 60
RATE_LIMIT_MAX=60

# Window size in seconds
# Default: 60
RATE_LIMIT_WINDOW=60

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins (comma-separated)
# Default: *
CORS_ALLOWED_ORIGINS=*

# Allowed HTTP methods (comma-separated)
# Default: GET,OPTIONS
CORS_ALLOWED_METHODS=GET,OPTIONS

# Allowed headers (comma-separated)
# Default: Content-Type
CORS_ALLOWED_HEADERS=Content-Type

# Max age for preflight cache in seconds
# Default: 86400 (24 hours)
CORS_MAX_AGE_SECONDS=86400

# =============================================================================
# Cloudflare Worker Bindings (configured in wrangler.toml)
# =============================================================================

# D1 Database ID (used in wrangler.toml: ${D1_DATABASE_ID})
D1_DATABASE_ID=your-d1-database-id-here

# KV Namespace IDs for route caching (used in wrangler.toml: ${ROUTE_CACHE_KV_ID})
ROUTE_CACHE_KV_ID=your-route-cache-kv-id
ROUTE_CACHE_PREVIEW_ID=your-route-cache-preview-id

# KV Namespace IDs for station caching (used in wrangler.toml: ${STATION_CACHE_KV_ID})
STATION_CACHE_KV_ID=your-station-cache-kv-id
STATION_CACHE_PREVIEW_ID=your-station-cache-preview-id

# Secrets (set via: wrangler secret put <NAME>)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# OPENCHARGEMAP_API_KEY=your-ocm-api-key
