{
  "name": "ev-overlay",
  "version": "1.2.0",
  "description": "Smart EV Overlay for Google Maps - Cloudflare-first trip planning",
  "private": true,
  "type": "module",
  "scripts": {
    "version:sync": "node scripts/sync-version.js",
    "version:inject": "node scripts/inject-version.js",
    "build": "pnpm version:sync && pnpm -r build && pnpm version:inject",
    "dev": "pnpm --filter @ev/web dev",
    "dev:all": "concurrently \"pnpm --filter @ev/api dev\" \"pnpm --filter @ev/web dev\" --names API,WEB --prefix-colors cyan,green",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:e2e": "pnpm --filter @ev/web test:e2e",
    "lint": "eslint . --ext .ts,.vue,.tsx",
    "lint:fix": "eslint . --ext .ts,.vue,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,vue,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^6.14.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.19.2",
    "husky": "^9.1.7",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0"
}
