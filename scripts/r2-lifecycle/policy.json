{
  "rules": [
    {
      "id": "snapshot-retention-90-days",
      "status": "enabled",
      "filter": {
        "prefix": "snapshots/"
      },
      "expiration": {
        "days": 90
      },
      "abortIncompleteMultipartUpload": {
        "daysAfterInitiation": 7
      }
    },
    {
      "id": "temporary-logs-cleanup",
      "status": "enabled",
      "filter": {
        "prefix": "temp/"
      },
      "expiration": {
        "days": 7
      }
    },
    {
      "id": "old-logs-transition",
      "status": "enabled",
      "filter": {
        "prefix": "logs/"
      },
      "transition": [
        {
          "storageClass": "InfrequentAccess",
          "days": 30
        }
      ],
      "expiration": {
        "days": 365
      }
    }
  ]
}
